# Copy this file to `.env.local` and fill in real values.
# Next.js only auto-loads `.env.local` (and `.env`), NOT `.env.example`.

NEXT_PUBLIC_APP_URL=http://localhost:3000

# MongoDB Atlas — Database → Connect → Drivers → Node.js connection string
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/aitrade?retryWrites=true&w=majority

# JWT (long random string, 32+ characters)
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars

# Admin: în MongoDB setează `role: "admin"` pe user; apoi login din nou. Ruta /admin e în shell + middleware.

# AES-256-GCM: exactly 64 hex characters (32 bytes). Generate e.g. `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Opțional: dacă Binance returnează -1021 (timestamp ahead), mărește treptat (ex. 500–900). Implicit ~450 ms.
# BINANCE_TIME_SKEW_MS=600

# Upstash Redis (REST)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# EasyCron (GET /api/cron/run-bots) + Vercel env: același secret în Authorization: Bearer …
CRON_SECRET=change-me-cron-secret

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ELITE=price_...

# AI API — fallback global dacă utilizatorul nu își pune chei proprii în Setări (BYOK în DB criptat)
GEMINI_API_KEY=AI...
GEMINI_API_MODEL=gemini-2.5-flash

# Anthropic Claude — fallback global
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Ollama — fallback dacă utilizatorul nu pune URL/model în Setări (inferență pe host-ul unde rulează API-ul)
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2
